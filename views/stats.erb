<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="refresh" content="30">
  <title>Bot Stats</title>
  <style>
    body { background: #0d0d0d; color: #c8c8c8; font-family: monospace; font-size: 12px; margin: 0; padding: 12px; }
    nav { margin-bottom: 10px; }
    nav a { color: #5af; text-decoration: none; margin-right: 16px; font-size: 13px; }
    nav a:hover { text-decoration: underline; }
    h1 { color: #fff; font-size: 15px; margin: 0 0 4px; }
    .meta { color: #666; margin-bottom: 14px; font-size: 11px; }
    table { border-collapse: collapse; width: 100%; }
    th { background: #1a1a1a; color: #aaa; text-align: left; padding: 6px 10px; font-size: 11px; border-bottom: 1px solid #333; }
    td { padding: 5px 10px; border-bottom: 1px solid #1f1f1f; }
    tr:hover td { background: #141414; }
    .asset { color: #fff; font-weight: bold; }
    .good { color: #4caf50; }
    .bad  { color: #f44336; }
    .warn { color: #ffc94d; }
    .dim  { color: #555; }
    .group { background: #111; color: #666; font-size: 10px; padding: 3px 10px; letter-spacing: 1px; text-transform: uppercase; }
    .rate { font-size: 11px; }
    .empty { color: #333; text-align: center; padding: 30px; }
  </style>
</head>
<body>
  <nav>
    <a href="/">Log</a>
    <a href="/stats">Stats</a>
    <a href="/results">Results</a>
  </nav>
  <h1>Trade Stats by Asset</h1>
  <div class="meta">Last updated: <%= time %> &nbsp;|&nbsp; <a href="/stats">Refresh</a> &nbsp;|&nbsp; auto-refreshes every 30s</div>

  <% if stats.empty? %>
    <div class="empty">No stats:trade:* keys in Redis yet — data accumulates as the bot trades.</div>
  <% else %>
  <table>
    <thead>
      <tr>
        <th rowspan="2">Asset</th>
        <th colspan="3">Alignment</th>
        <th colspan="3">CLOB</th>
        <th colspan="4">Outcome</th>
        <th rowspan="2">Win Rate</th>
      </tr>
      <tr>
        <th>Pass</th><th>Fail</th><th>Rate</th>
        <th>Placed</th><th>Fail</th><th>Rate</th>
        <th>TP</th><th>SL</th><th>Trail</th><th>Expiry</th><th>Correct</th>
      </tr>
    </thead>
    <tbody>
      <% stats.each do |asset, s| %>
      <tr>
        <td class="asset"><%= asset %></td>

        <%# Alignment %>
        <td class="<%= s[:alignment_pass] > 0 ? 'good' : 'dim' %>"><%= s[:alignment_pass] %></td>
        <td class="<%= s[:alignment_fail] > 0 ? 'bad' : 'dim' %>"><%= s[:alignment_fail] %></td>
        <td class="rate <%= s[:alignment_rate] && s[:alignment_rate] >= 50 ? 'good' : 'bad' %>">
          <%= s[:alignment_rate] ? "#{s[:alignment_rate]}%" : '—' %>
        </td>

        <%# CLOB %>
        <td class="<%= s[:order_placed] > 0 ? 'good' : 'dim' %>"><%= s[:order_placed] %></td>
        <td class="<%= s[:clob_fail] > 0 ? 'bad' : 'dim' %>"><%= s[:clob_fail] %></td>
        <td class="rate <%= s[:clob_rate] && s[:clob_rate] >= 50 ? 'good' : 'bad' %>">
          <%= s[:clob_rate] ? "#{s[:clob_rate]}%" : '—' %>
        </td>

        <%# Outcome %>
        <td class="<%= s[:tp] > 0 ? 'good' : 'dim' %>"><%= s[:tp] %></td>
        <td class="<%= s[:sl] > 0 ? 'bad' : 'dim' %>"><%= s[:sl] %></td>
        <td class="<%= s[:trail_stop] > 0 ? 'good' : 'dim' %>"><%= s[:trail_stop] %></td>
        <td class="<%= s[:expiry_close] > 0 ? 'warn' : 'dim' %>"><%= s[:expiry_close] %></td>
        <td><%= s[:correct] %></td>

        <%# Win Rate %>
        <td class="rate <%= s[:win_rate] && s[:win_rate] >= 50 ? 'good' : (s[:win_rate] ? 'bad' : 'dim') %>">
          <% if s[:win_rate] %>
            <%= s[:win_rate] %>% <span class="dim">(<%= s[:correct] %>/<%= s[:closed] %>)</span>
          <% else %>
            —
          <% end %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
  <% end %>

  <h2 style="color:#aaa;font-size:12px;letter-spacing:1px;text-transform:uppercase;margin:28px 0 8px;border-top:1px solid #1e1e1e;padding-top:16px;">Signal History</h2>
  <p style="color:#555;font-size:10px;margin:0 0 8px">
    <code>prices:signals</code> — written only when a trade is approved (used for win rate &amp; edge backtest).
    <code>prices:fairvalue</code> — written unconditionally every 30 s (used for fair value reference).
  </p>
  <% if stats.empty? %>
    <div class="empty">No data yet.</div>
  <% else %>
  <table>
    <thead>
      <tr>
        <th>Asset</th>
        <th>Signals total</th>
        <th>Pending (:na)</th>
        <th>Fairvalue total</th>
        <th>Should trade?</th>
      </tr>
    </thead>
    <tbody>
      <% stats.each do |asset, s| %>
      <tr>
        <td class="asset"><%= asset %></td>
        <td class="<%= s[:sig_total] > 50 ? 'good' : 'bad' %>"><%= s[:sig_total] %></td>
        <td class="<%= s[:sig_na] > 0 ? 'warn' : 'dim' %>"><%= s[:sig_na] %></td>
        <td class="<%= s[:fv_total] > 0 ? 'good' : 'bad' %>"><%= s[:fv_total] %></td>
        <td class="<%= s[:sig_total] > 50 ? 'good' : 'bad' %>">
          <%= s[:sig_total] > 50 ? 'YES (>50 records)' : "NO (need #{[51 - s[:sig_total], 0].max} more)" %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>
  <% end %>

  <%# ── Raw Signals (pre-edge) ──────────────────────────────────────────────── %>
  <h2 style="color:#aaa;font-size:12px;letter-spacing:1px;text-transform:uppercase;margin:28px 0 8px;border-top:1px solid #1e1e1e;padding-top:16px;">Raw Signals — pre-edge (paper trade tracker)</h2>
  <p style="color:#555;font-size:10px;margin:0 0 8px">
    <code>prices:signals_raw</code> — written at every aligned signal before the edge check. Outcome resolved at bar close. Win = token direction confirmed by Bybit.
  </p>
  <% if raw_sig_summary.empty? %>
    <div class="empty">No raw signal data yet.</div>
  <% else %>
  <table style="margin-bottom:18px">
    <thead>
      <tr>
        <th>Asset</th>
        <th>Total</th>
        <th>Pending</th>
        <th>Wins</th>
        <th>Losses</th>
        <th>Win Rate</th>
      </tr>
    </thead>
    <tbody>
      <% raw_sig_summary.each do |asset, s| %>
      <tr>
        <td class="asset"><%= asset %></td>
        <td><%= s[:total] %></td>
        <td class="<%= s[:pending] > 0 ? 'warn' : 'dim' %>"><%= s[:pending] %></td>
        <td class="<%= s[:wins] > 0 ? 'good' : 'dim' %>"><%= s[:wins] %></td>
        <td class="<%= s[:losses] > 0 ? 'bad' : 'dim' %>"><%= s[:losses] %></td>
        <td class="rate <%= s[:win_rate] ? (s[:win_rate] >= 50 ? 'good' : 'bad') : 'dim' %>">
          <% if s[:win_rate] %>
            <%= s[:win_rate] %>% <span class="dim">(<%= s[:wins] %>/<%= s[:wins] + s[:losses] %>)</span>
          <% else %>
            —
          <% end %>
        </td>
      </tr>
      <% end %>
    </tbody>
  </table>

  <% if raw_sig_recent.any? %>
  <table>
    <thead>
      <tr>
        <th>Time (UTC)</th>
        <th>Asset</th>
        <th>Token</th>
        <th>Bybit%</th>
        <th>PM Price</th>
        <th>Bybit</th>
        <th>CB</th>
        <th>CL</th>
        <th>Agree</th>
        <th>Outcome</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      <% raw_sig_recent.each do |r| %>
      <%
        result_cls = r[:win].nil? ? 'warn' : (r[:win] ? 'good' : 'bad')
        result_lbl = r[:win].nil? ? 'pending' : (r[:win] ? 'WIN' : 'LOSS')
        out_cls    = r[:outcome] == 'na' ? 'dim' : (r[:outcome] == 'up' ? 'good' : 'bad')
        bybit_cls  = r[:bybit_pct] > 0 ? 'good' : 'bad'
      %>
      <tr>
        <td class="dim"><%= Time.at(r[:ts]).utc.strftime('%m-%d %H:%M') %></td>
        <td class="asset"><%= r[:asset] %></td>
        <td class="dim"><%= r[:token] %></td>
        <td class="<%= bybit_cls %>"><%= r[:bybit_pct] > 0 ? '+' : '' %><%= r[:bybit_pct].round(2) %>%</td>
        <td class="dim"><%= r[:pm_price].round(3) %></td>
        <td class="<%= r[:bybit_dir] == 'UP' ? 'good' : 'bad' %>"><%= r[:bybit_dir] %></td>
        <td class="<%= r[:cb_dir] == 'UP' ? 'good' : 'bad' %>"><%= r[:cb_dir] %></td>
        <td class="<%= r[:cl_dir].empty? ? 'dim' : (r[:cl_dir] == 'UP' ? 'good' : 'bad') %>"><%= r[:cl_dir].empty? ? '—' : r[:cl_dir] %></td>
        <td class="dim"><%= r[:agree] %></td>
        <td class="<%= out_cls %>"><%= r[:outcome] == 'na' ? '…' : r[:outcome] %></td>
        <td class="<%= result_cls %>"><b><%= result_lbl %></b></td>
      </tr>
      <% end %>
    </tbody>
  </table>
  <% end %>
  <% end %>
</body>
</html>
