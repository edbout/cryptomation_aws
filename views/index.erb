<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: monospace;
      font-size: 14px;
      background: #000;
      color: #eee;
      padding: 10px;
    }
    header {
      background: #222;
      padding: 10px;
      margin-bottom: 10px;
      border-radius: 4px;
      font-size: 16px;
      font-weight: bold;
    }
    header small {
      display: block;
      font-size: 12px;
      opacity: 0.7;
    }
    pre {
      margin: 0;
      padding: 8px;
      background: #111;
      border-radius: 4px;
      border: 1px solid #333;
      white-space: pre-wrap;
      word-wrap: break-word;
      max-height: calc(100vh - 120px);
      overflow-y: auto;
    }
    mark.info {
        background: #003300;
        color: #6ddb6d;
        padding: 0 2px;
    }
    mark.err {
        background: #400;
        color: #f00;
        font-weight: bold;
        padding: 0 2px;
    }
    /* Add this new block */
    mark.warn {
        background: #440;
        color: #ff0;
        font-weight: bold;
        padding: 0 2px;
    }
    footer {
      margin-top: 10px;
      font-size: 12px;
      opacity: 0.7;
    }
  </style>
</head>
<body>
  <header><%= title %>
    <small>Path: <%= log_path %> | Time: <%= time %></small>
  </header>

  <main>
    <pre><%= log_lines.join("\n") %></pre>
  </main>

  <footer>Auto‑refreshing every 5 seconds. Press F5 to refresh manually.</footer>

  <script>
    setInterval(() => {
      fetch('/health')
        .then(r => r.json())
        .then(json => {
          document.querySelector('small').textContent =
            `Path: <%= log_path %> | Time: ${json.time}`;
        })
        .catch(() => {});
    }, 5000);
  </script>
</body>
</html>