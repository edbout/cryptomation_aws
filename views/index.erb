<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta http-equiv="refresh" content="10">
  <title><%= title %></title>
  <style>
    body { background: #0d0d0d; color: #c8c8c8; font-family: monospace; font-size: 12px; margin: 0; padding: 12px; }
    nav { margin-bottom: 10px; }
    nav a { color: #5af; text-decoration: none; margin-right: 16px; font-size: 13px; }
    nav a:hover { text-decoration: underline; }
    h1 { color: #fff; font-size: 15px; margin: 0 0 4px; }
    .meta { color: #666; margin-bottom: 8px; font-size: 11px; }
    pre { white-space: pre-wrap; word-break: break-all; line-height: 1.5; margin: 0; }
    mark.err  { background: #5a0000; color: #ff6b6b; border-radius: 2px; padding: 0 2px; }
    mark.warn { background: #3d2e00; color: #ffc94d; border-radius: 2px; padding: 0 2px; }
    mark.info { background: transparent; color: #888; }
  </style>
</head>
<body>
  <nav>
    <a href="/">Log</a>
    <a href="/stats">Stats</a>
    <a href="/results">Results</a>
  </nav>
  <h1><%= title %></h1>
  <div class="meta">Last updated: <%= time %> &nbsp;|&nbsp; <a href="/">Refresh</a></div>
  <pre><%= log_lines.join("\n") %></pre>
</body>
</html>
